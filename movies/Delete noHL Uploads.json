{
  "_slug": "delete-nohl-uploads",
  "name": "Delete: noHL Uploads",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "delete": {
      "enabled": true,
      "mode": "deleteWithFilesPreserveCrossSeeds",
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "field": "TAGS",
            "operator": "EQUAL",
            "value": "upload"
          },
          {
            "field": "TAGS",
            "operator": "EQUAL",
            "value": "noHL"
          },
          {
            "field": "COMPLETION_ON",
            "operator": "GREATER_THAN",
            "value": "31536000"
          },
          {
            "field": "LAST_ACTIVITY",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": "21600"
          },
          {
            "field": "NUM_COMPLETE",
            "operator": "GREATER_THAN_OR_EQUAL",
            "value": "3"
          }
        ]
      }
    }
  },
  "intervalSeconds": 86400,
  "sortOrder": 5
}