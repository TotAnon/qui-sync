{
  "_slug": "resume-if-torrent-gets-completed-for-no-reason",
  "name": "Resume: If torrent gets Completed for no reason",
  "trackerPattern": "*",
  "trackerDomains": [
    "*"
  ],
  "conditions": {
    "schemaVersion": "1",
    "resume": {
      "enabled": true,
      "condition": {
        "operator": "AND",
        "conditions": [
          {
            "operator": "OR",
            "conditions": [
              {
                "field": "STATE",
                "operator": "EQUAL",
                "value": "completed"
              },
              {
                "field": "STATE",
                "operator": "EQUAL",
                "value": "stopped"
              }
            ]
          },
          {
            "field": "PROGRESS",
            "operator": "EQUAL",
            "value": "1"
          }
        ]
      }
    }
  },
  "sortOrder": 7
}